{
  "name": "@shade-protocol/circuits",
  "version": "0.1.0",
  "description": "Shade Protocol privacy circuits (Circom/Groth16)",
  "private": true,
  "scripts": {
    "build": "bash scripts/build.sh",
    "clean": "rm -rf build",
    "compile": "circom src/main.circom --r1cs --wasm --sym -o build -l node_modules",
    "setup": "bash scripts/build.sh --setup-only",
    "test": "node test/test_joinsplit.js",
    "verify": "snarkjs r1cs info build/main.r1cs"
  },
  "dependencies": {
    "circomlib": "2.0.5"
  },
  "devDependencies": {
    "@noble/hashes": "^1.4.0",
    "circomlibjs": "^0.1.7",
    "snarkjs": "0.7.4"
  }
}
